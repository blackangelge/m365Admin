# ── Anwendung ──────────────────────────────────────────────────────────────────
# Geheimschlüssel für signierte Cookies (generieren: python -c "import secrets; print(secrets.token_hex(32))")
APP_SECRET_KEY=changeme-replace-with-secrets-token-hex-32
APP_SESSION_COOKIE_NAME=m365admin_session
APP_DEBUG=false

# ── Datenbank ──────────────────────────────────────────────────────────────────
# Vier Schrägstriche = absoluter Pfad im Container (/data/m365admin.db)
DATABASE_URL=sqlite+aiosqlite:////data/m365admin.db

# ── Microsoft 365 / Azure AD ───────────────────────────────────────────────────
# Alle Werte aus der Azure Portal App-Registrierung (siehe SETUP.md)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-value-here

# Muss exakt mit der Redirect-URI in Azure übereinstimmen
# Ersetze <HOST-IP> mit der IP-Adresse dieses Servers (z.B. 192.168.1.100)
AZURE_REDIRECT_URI=https://<HOST-IP>/auth/callback

# Berechtigungen (Leerzeichen-getrennt)
AZURE_SCOPES=openid profile email User.Read

# ── Administrator ──────────────────────────────────────────────────────────────
# Diese E-Mail-Adresse wird beim Login automatisch als Administrator gesetzt
ADMIN_EMAIL=admin@deine-organisation.de

# ── TLS-Zertifikat (wird beim ersten Start automatisch generiert) ───────────────
# IP-Adresse des Servers — wird als Subject Alternative Name (SAN) ins Zertifikat eingetragen
# Gleicher Wert wie in AZURE_REDIRECT_URI (ohne https:// und Pfad)
CERT_IP=<HOST-IP>
# Anzeigename im Zertifikat (CN-Feld)
CERT_CN=m365admin
# Gültigkeitsdauer in Tagen
CERT_DAYS=365
